
---

## 📄 Recommended content for Spring Boot project

```gitignore
# =========================
# Java / Spring Boot
# =========================

target/
*.class
*.jar
*.war

# Maven
.mvn/
mvnw
mvnw.cmd

# =========================
# IntelliJ IDEA
# =========================
.idea/
*.iml
out/

# =========================
# Eclipse / STS
# =========================
.classpath
.project
.settings/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Environment variables
# =========================
.env

# =========================
# Database / local files
# =========================
*.db
*.sqlite

# =========================
# Spring Boot configs (optional safety)
# =========================
application-local.properties
application-dev.properties
application.perperties
# =========================
# Build folders
# =========================
build/